{
  "name": "dev-dashboards",
  "version": "2.0.0",
  "description": "TV-optimized engineering dashboards for MadHive services",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "start": "bun run server/index.js",
    "dev": "bun --watch server/index.js",
    "lint": "echo 'No linter configured - skipping' && exit 0",
    "typecheck": "echo 'No TypeScript typecheck - vanilla JS project' && exit 0",
    "test": "bun test tests/unit tests/integration tests/helpers tests/components",
    "test:all": "bun test",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:e2e": "bun test tests/e2e",
    "test:watch": "bun test --watch tests/unit tests/integration tests/components",
    "test:coverage": "bun test --coverage tests/unit tests/integration tests/helpers tests/components",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio --port 4983",
    "build": "echo 'No build step required for vanilla JS' && exit 0"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1000.0",
    "@datadog/datadog-api-client": "^1.52.0",
    "@elastic/elasticsearch": "^9.3.2",
    "@elysiajs/cookie": "^0.8.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/static": "^1.2",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/monitoring": "^5.3.1",
    "@libsql/client": "^0.17.0",
    "axios": "^1.13.6",
    "drizzle-orm": "^0.38.0",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.2",
    "elysia-rate-limit": "^4.5.0",
    "google-auth-library": "^10.6.1",
    "js-yaml": "^4.1.0",
    "jsforce": "^3.10.14",
    "node-zendesk": "^6.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.0",
    "jsdom": "^28.1.0",
    "whatwg-url": "7.1.0"
  }
}
